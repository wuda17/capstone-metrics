_to_time_ratio": 0.7124, "mean_pause_duration_sec": 0.688, "f0_mean_hz": 176.6851, "jitter_local": 0.032497, "shimmer_local_db": 1.205818, "emotion_score": 0.0, "self_pronoun_ratio": 0.09090909090909091, "type_token_ratio": 0.9090909090909091}}, {"segment_start": "2026-03-16T15:06:00Z", "segment_end": "2026-03-16T15:07:00Z", "sample_count": 1, "values": {"speech_rate_wpm": 126.55, "articulation_rate_wpm": 138.525, "phonation_to_time_ratio": 0.7483, "mean_pause_duration_sec": 0.716, "f0_mean_hz": 183.3219, "jitter_local": 0.032627, "shimmer_local_db": 1.401186, "emotion_score": 0.076923, "self_pronoun_ratio": 0.05, "type_token_ratio": 0.8}}, {"segment_start": "2026-03-16T16:55:00Z", "segment_end": "2026-03-16T16:56:00Z", "sample_count": 1, "values": {"speech_rate_wpm": 116.846, "articulation_rate_wpm": 150.896, "phonation_to_time_ratio": 0.724, "mean_pause_duration_sec": 0.69, "f0_mean_hz": 202.8177, "jitter_local": 0.032974, "shimmer_local_db": 1.544275, "emotion_score": 0.076923, "self_pronoun_ratio": 0.0, "type_token_ratio": 0.8461538461538461}}, {"segment_start": "2026-03-17T10:54:00Z", "segment_end": "2026-03-17T10:55:00Z", "sample_count": 1, "values": {"speech_rate_wpm": 118.969, "articulation_rate_wpm": 148.168, "phonation_to_time_ratio": 0.7681, "mean_pause_duration_sec": 0.644, "f0_mean_hz": 186.141, "jitter_local": 0.034669, "shimmer_local_db": 1.276339, "emotion_score": 0.085714, "self_pronoun_ratio": 0.08571428571428572, "type_token_ratio": 0.8857142857142857}}, {"segment_start": "2026-03-17T14:50:00Z", "segment_end": "2026-03-17T14:51:00Z", "sample_count": 1, "values": {"speech_rate_wpm": 111.35, "articulation_rate_wpm": 150.831, "phonation_to_time_ratio": 0.7636, "mean_pause_duration_sec": 0.723, "f0_mean_hz": 184.9576, "jitter_local": 0.032794, "shimmer_local_db": 1.356583, "emotion_score": 0.085714, "self_pronoun_ratio": 0.05714285714285714, "type_token_ratio": 0.8}}, {"segment_start": "2026-03-18T10:37:00Z", "segment_end": "2026-03-18T10:38:00Z", "sample_count": 1, "values": {"speech_rate_wpm": 126.188, "articulation_rate_wpm": 144.181, "phonation_to_time_ratio": 0.7501, "mean_pause_duration_sec": 0.772, "f0_mean_hz": 192.7501, "jitter_local": 0.034209, "shimmer_local_db": 1.55924, "emotion_score": -0.040541, "self_pronoun_ratio": 0.02702702702702703, "type_token_ratio": 0.972972972972973}}, {"segment_start": "2026-03-18T14:54:00Z", "segment_end": "2026-03-18T14:55:00Z", "sample_count": 1, "values": {"speech_rate_wpm": 113.919, "articulation_rate_wpm": 138.344, "phonation_to_time_ratio": 0.719, "mean_pause_duration_sec": 0.779, "f0_mean_hz": 188.7815, "jitter_local": 0.034565, "shimmer_local_db": 1.377845, "emotion_score": -0.040541, "self_pronoun_ratio": 0.030303030303030304, "type_token_ratio": 0.8787878787878788}}], "baseline": {"method": "earliest_percent", "percent": 0.25, "sample_count": 6, "values": {"speech_rate_wpm": 148.359667, "articulation_rate_wpm": 161.741667, "phonation_to_time_ratio": 0.766517, "mean_pause_duration_sec": 0.529333, "f0_mean_hz": 200.21625, "jitter_local": 0.023111, "shimmer_local_db": 1.028672, "emotion_score": 0.054429, "self_pronoun_ratio": 0.08018867924528301, "type_token_ratio": 0.660377358490566}}, "current": {"window_minutes": 60, "sample_count": 0, "values": {"speech_rate_wpm": null, "articulation_rate_wpm": null, "phonation_to_time_ratio": null, "mean_pause_duration_sec": null, "f0_mean_hz": null, "jitter_local": null, "shimmer_local_db": null, "emotion_score": 0.0, "self_pronoun_ratio": 0.0, "type_token_ratio": 0.0}}}, "transcripts": {"items": [{"event_time": "2026-03-18T14:54:00.194851+00:00", "day": "2026-03-18", "source_file": "session_024.wav", "text": "Feeling more like myself today. Had a proper breakfast and did some watering in the garden. The sweet peas are coming along beautifully. Might cut some for the vase on the kitchen table.", "word_count": 33}, {"event_time": "2026-03-18T10:37:00.771476+00:00", "day": "2026-03-18", "source_file": "session_023.wav", "text": "Had a lovely dream about John last night. We were dancing, like we used to at the village hall. Woke up feeling sad but also warm, if that makes sense. I still miss him every single day.", "word_count": 37}, {"event_time": "2026-03-17T14:50:00.477110+00:00", "day": "2026-03-17", "source_file": "session_022.wav", "text": "Finished the puzzle I have been working on for two weeks, the one with the flowers. One thousand pieces. Felt very satisfied when I put the last piece in. Might start the castle one next.", "word_count": 35}, {"event_time": "2026-03-17T10:54:00.247861+00:00", "day": "2026-03-17", "source_file": "session_021.wav", "text": "Not feeling well today, think I might be coming down with a cold. My throat is scratchy and I feel quite tired. Took some paracetamol and had a hot drink. Just resting and watching television.", "word_count": 35}, {"event_time": "2026-03-16T16:55:00.968114+00:00", "day": "2026-03-16", "source_file": "session_020.wav", "text": "Spoke to Michael about possibly going to visit the coast in the summer. He thinks it is a good idea. We used to go every year when the children were small. Would be nice to see the sea again.", "word_count": 39}, {"event_time": "2026-03-16T15:06:00.063556+00:00", "day": "2026-03-16", "source_file": "session_019.wav", "text": "Had a bit of a fall in the garden this morning, just tripped on the step. Not hurt, just a bit shaken. Sat down for a while. I need to be more careful. Maybe I should get that step fixed.", "word_count": 40}, {"event_time": "2026-03-15T10:30:00.846721+00:00", "day": "2026-03-15", "source_file": "session_018.wav", "text": "Feeling much brighter today. The sun is out and I have energy. Made a proper cooked breakfast and did some tidying. Put on some music while I cleaned. Really felt like myself again.", "word_count": 33}, {"event_time": "2026-03-14T14:55:00.346479+00:00", "day": "2026-03-14", "source_file": "session_017.wav", "text": "Did some gentle stretching exercises this morning following that video Sarah showed me. My back felt much better afterwards. I should try to do it every morning if I remember to.", "word_count": 31}, {"event_time": "2026-03-13T09:15:00.235612+00:00", "day": "2026-03-13", "source_file": "session_016.wav", "text": "Went to the supermarket this morning. Bumped into my neighbour Patricia at the checkout. We chatted for a while about the new road works on the high street. Picked up some fresh flowers.", "word_count": 33}, {"event_time": "2026-03-12T10:27:00.222086+00:00", "day": "2026-03-12", "source_file": "session_015.wav", "text": "Feeling quite low today. Not sure what brought it on. The house feels very quiet. I keep thinking about things I should have done differently. Hope tomorrow is a better day for me.", "word_count": 33}, {"event_time": "2026-03-11T14:46:00.509597+00:00", "day": "2026-03-11", "source_file": "session_014.wav", "text": "My friend Dorothy came for tea this afternoon. We had not seen each other since Christmas. She looks well. We talked for nearly two hours. It was so good to have company in the house.", "word_count": 35}, {"event_time": "2026-03-10T10:20:00.512340+00:00", "day": "2026-03-10", "source_file": "session_013.wav", "text": "Slept quite poorly again. Keep waking at around three in the morning and then cannot get back to sleep. Feel groggy and slow today. Not much energy to do things. Just sat and watched television.", "word_count": 35}, {"event_time": "2026-03-09T15:40:00.312942+00:00", "day": "2026-03-09", "source_file": "session_012.wav", "text": "Made banana bread this afternoon. The whole house smells amazing. I put some walnuts in like my mother used to. I will save a slice for when the nurse comes tomorrow morning.", "word_count": 32}, {"event_time": "2026-03-08T09:07:00.307757+00:00", "day": "2026-03-08", "source_file": "session_011.wav", "text": "Book club was lovely today. We discussed that novel about the lighthouse keeper. Everyone had different opinions which made for a good conversation. I should read more often.", "word_count": 28}, {"event_time": "2026-03-07T10:29:00.554816+00:00", "day": "2026-03-07", "source_file": "session_010.wav", "text": "Felt a bit anxious this morning, not sure why. Just a general feeling of unease. I did my breathing exercises and that helped a little. Had a cup of tea and sat in the garden for a while.", "word_count": 38}, {"event_time": "2026-03-06T14:08:00.534277+00:00", "day": "2026-03-06", "source_file": "session_009.wav", "text": "I sorted through some old photographs this afternoon. Found pictures from our holiday in Portugal, must have been nineteen eighty-seven. So many good memories. I should put them in an album.", "word_count": 31}, {"event_time": "2026-03-05T11:58:00.674079+00:00", "day": "2026-03-05", "source_file": "session_008.wav", "text": "My grandson Tommy called me on video today. He's learning to read now and read me a whole page from his book. I was so proud of him. Children pick things up so quickly, it is remarkable.", "word_count": 37}, {"event_time": "2026-03-04T16:52:00.033659+00:00", "day": "2026-03-04", "source_file": "session_007.wav", "text": "Went for my morning walk along the river path. Saw a heron standing very still by the water. Walked for about forty minutes. My knee was a bit stiff at the start but got better.", "word_count": 35}, {"event_time": "2026-03-03T09:46:00.256702+00:00", "day": "2026-03-03", "source_file": "session_006.wav", "text": "Been thinking about my mother a lot today. She would have turned eighty-three this week. I miss her very much. We used to bake together every Sunday morning when I was young.", "word_count": 32}, {"event_time": "2026-03-02T10:29:00.666563+00:00", "day": "2026-03-02", "source_file": "session_005.wav", "text": "Tried a new recipe for chicken soup today. Added some ginger and it turned out quite good. The kitchen smelled wonderful. I might make it again next week for when the grandchildren visit.", "word_count": 33}, {"event_time": "2026-03-01T15:55:00.379201+00:00", "day": "2026-03-01", "source_file": "session_004.wav", "text": "I watched that documentary about penguins last night. It was absolutely fascinating, I didn't know they could swim so fast. I told Michael about it and he wants to watch it too.", "word_count": 32}, {"event_time": "2026-02-28T11:22:00.633052+00:00", "day": "2026-02-28", "source_file": "session_003.wav", "text": "The doctor's appointment went alright. He said my blood pressure is a little high but nothing too concerning. I just need to watch my salt intake and keep walking every day. I feel okay about it.", "word_count": 36}, {"event_time": "2026-02-27T09:00:00.795667+00:00", "day": "2026-02-27", "source_file": "session_002.wav", "text": "Had a wonderful phone call with my sister Margaret this morning. She told me about her garden and how the tomatoes are doing really well this year. We laughed so much, it was lovely to catch up.", "word_count": 37}, {"event_time": "2026-02-26T14:05:00.229258+00:00", "day": "2026-02-26", "source_file": "session_001.wav", "text": "I've been feeling a bit tired lately, not sleeping as well as I used to. Woke up a few times last night. Maybe I should try that chamomile tea again. I think the heat has been affecting me.", "word_count": 38}, {"event_time": "2026-02-25T10:40:00.116739+00:00", "day": "2026-02-25", "source_file": "session_000.wav", "text": "Today I went to the park with my daughter Sarah. The weather was just beautiful, really lovely. We fed the ducks and had ice cream after. It was a really nice afternoon, I felt very relaxed.", "word_count": 36}]}, "alerts": {"items": [{"status": "alert", "severity": "high", "metric": "emotion_score", "delta_pct": -100.0, "trend": "down", "message": "emotion_score is 100.0% below baseline."}, {"status": "alert", "severity": "high", "metric": "self_pronoun_ratio", "delta_pct": -100.0, "trend": "down", "message": "self_pronoun_ratio is 100.0% below baseline."}, {"status": "alert", "severity":