{"meta": {"schema_version": "2.0.0", "generated_at": "2026-03-18T21:01:10.958407Z", "segment_minutes": 1, "snapshot_count": 25}, "metrics": {"time_series": [{"segment_start": "2026-02-25T10:40:00Z", "segment_end": "2026-02-25T10:41:00Z", "sample_count": 1, "values": {"speech_rate_wpm": 147.761, "articulation_rate_wpm": 158.258, "phonation_to_time_ratio": 0.7889, "mean_pause_duration_sec": 0.538, "f0_mean_hz": 197.4113, "jitter_local": 0.02024, "shimmer_local_db": 1.032866, "emotion_score": 0.083333, "self_pronoun_ratio": 0.08333333333333333, "type_token_ratio": 0.8611111111111112}}, {"segment_start": "2026-02-26T14:05:00Z", "segment_end": "2026-02-26T14:06:00Z", "sample_count": 1, "values": {"speech_rate_wpm": 146.609, "articulation_rate_wpm": 161.961, "phonation_to_time_ratio": 0.7937, "mean_pause_duration_sec": 0.589, "f0_mean_hz": 192.5778, "jitter_local": 0.02341, "shimmer_local_db": 0.92665, "emotion_score": 0.0, "self_pronoun_ratio": 0.10526315789473684, "type_token_ratio": 0.868421052631579}}, {"segment_start": "2026-02-27T09:00:00Z", "segment_end": "2026-02-27T09:01:00Z", "sample_count": 1, "values": {"speech_rate_wpm": 151.381, "articulation_rate_wpm": 166.419, "phonation_to_time_ratio": 0.7764, "mean_pause_duration_sec": 0.554, "f0_mean_hz": 198.3146, "jitter_local": 0.022612, "shimmer_local_db": 0.995026, "emotion_score": 0.243243, "self_pronoun_ratio": 0.05405405405405406, "type_token_ratio": 0.972972972972973}}, {"segment_start": "2026-02-28T11:22:00Z", "segment_end": "2026-02-28T11:23:00Z", "sample_count": 1, "values": {"speech_rate_wpm": 151.41, "articulation_rate_wpm": 154.427, "phonation_to_time_ratio": 0.7014, "mean_pause_duration_sec": 0.49, "f0_mean_hz": 190.6735, "jitter_local": 0.026628, "shimmer_local_db": 1.103141, "emotion_score": 0.0, "self_pronoun_ratio": 0.1111111111111111, "type_token_ratio": 0.9444444444444444}}, {"segment_start": "2026-03-01T15:55:00Z", "segment_end": "2026-03-01T15:56:00Z", "sample_count": 1, "values": {"speech_rate_w