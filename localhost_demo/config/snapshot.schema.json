{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LocalhostDemoSnapshot",
  "type": "object",
  "required": [
    "event",
    "source_file",
    "transcript",
    "metrics"
  ],
  "properties": {
    "event": {
      "type": "object",
      "required": ["time", "day"],
      "properties": {
        "time": { "type": "string" },
        "day": { "type": "string" }
      }
    },
    "source_file": { "type": "string" },
    "transcript": { "type": "string" },
    "metrics": {
      "type": "object",
      "required": ["temporal", "lexical", "prosody", "spectral"],
      "additionalProperties": false,
      "properties": {
        "temporal": { "type": "object" },
        "lexical": { "type": "object" },
        "prosody": { "type": "object" },
        "spectral": { "type": "object" }
      }
    }
  }
}
